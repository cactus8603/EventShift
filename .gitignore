# Python caches
__pycache__/
*.py[cod]
*$py.class

# Native build artifacts
*.so
*.o
*.d
*.ninja
*.egg
*.egg-info/
build/
dist/
.ninja_deps
.ninja_log

# Local environments
.venv/
venv/
env/
.conda/

# Large local data / generated outputs / checkpoints
data/*
!data/README.md
outputs/*
!outputs/README.md
artifacts/*
!artifacts/README.md
checkpoints/*
!checkpoints/README.md
submit/*.zip
!submit/README.md
work_dirs/*
!work_dirs/README.md

# Generated prediction / rebuild artifact types
outputs/**/*.png
outputs/**/*.json
outputs/**/*.txt
outputs/**/*.zip
artifacts/**/*.json
artifacts/**/*.txt
artifacts/**/*.zip

# Logs and temporary files
*.log
*.tmp
*.bak
