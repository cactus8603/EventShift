# Python caches
__pycache__/
*.py[cod]
*$py.class

# Native build artifacts
*.so
*.o
*.egg
*.egg-info/
build/
dist/
.ninja_deps
.ninja_log

# Local environments
.venv/
venv/
env/
.conda/

# Large local data / generated outputs / checkpoints
data/*
